# ============================================================
#  IBM watsonx.ai Credentials — copy this file to .env
#  and fill in your actual values. Never commit .env to Git.
# ============================================================

# IBM Cloud API Key (from https://cloud.ibm.com/iam/apikeys)
IBM_API_KEY=your_ibm_cloud_api_key_here

# watsonx.ai Project ID (from your watsonx.ai project settings)
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# watsonx.ai API URL — use the region matching your IBM Cloud account:
#   Dallas (US):  https://us-south.ml.cloud.ibm.com
#   Sydney (AP):  https://au-syd.ml.cloud.ibm.com
#   Frankfurt:    https://eu-de.ml.cloud.ibm.com
#   London:       https://eu-gb.ml.cloud.ibm.com
WATSONX_URL=https://au-syd.ml.cloud.ibm.com

# Granite Model ID — use one that your region/plan supports.
# To list available models run:
#   python -c "from ibm_watsonx_ai import APIClient, Credentials; import os; from dotenv import load_dotenv; load_dotenv(); c=APIClient(Credentials(os.getenv('WATSONX_URL'),api_key=os.getenv('IBM_API_KEY')),project_id=os.getenv('WATSONX_PROJECT_ID')); [print(m['model_id']) for m in c.foundation_models.get_model_specs()['resources']]"
#
# Recommended for au-syd region (change if using us-south):
#   ibm/granite-8b-code-instruct      ← BEST for au-syd (instruct, text_generation ✓)
#   meta-llama/llama-3-3-70b-instruct ← Highest quality, au-syd (instruct ✓)
#   ibm/granite-guardian-3-8b         ← au-syd (instruct, text_generation ✓)
#   ibm/granite-3-8b-instruct         ← us-south only
#   ibm/granite-13b-instruct-v2       ← us-south only
WATSONX_MODEL_ID=ibm/granite-8b-code-instruct

# Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=change_this_to_a_random_secret_key

# Flask environment
FLASK_ENV=development
FLASK_DEBUG=True
